{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mangiadesk",
  "version": "0.1.0",
  "identifier": "com.mangiadesk.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mangia Desktop",
        "width": 1366,
        "height": 720
      }
    ],
    "security": {
      "csp": "default-src 'self' http://192.168.31.123:5999; img-src 'self' http://192.168.31.123:5999 data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; connect-src 'self' http://192.168.31.123:5999"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
